library(sf)
library(dplyr)
gdb <- "D:/GIS/projects/GreaterYellowstoneCoalition/GYC_Map_Viewer/data/IFWIS_DataRequest__GYC_MigrationsStopovers_042026/DataRequest_042026.gdb"
layer_names <- st_layers(gdb)$name
# ── Species lookup ────────────────────────────────────────────────────────────
species_lookup <- c(
"MD"       = "Mule Deer",
"Elk"      = "Elk",
"Pronghorn"= "Pronghorn",
"Moose"    = "Moose"
)
# ── Parse layer name into components ─────────────────────────────────────────
# Expected pattern:  <Species>_<Herd...>_<Type>_<Year>
# Type tokens: Migration_Route (two tokens) or Stopover(s) (one token)
parse_layer_name <- function(nm) {
parts <- strsplit(nm, "_")[[1]]
# Identify species prefix (first token)
species_code <- parts[1]
species <- ifelse(species_code %in% names(species_lookup),
species_lookup[species_code], species_code)
# Year is always the last token
year <- tail(parts, 1)
# Route type: check for "Migration" + "Route" pair or "Stopover(s)"
remaining <- parts[-c(1, length(parts))]  # drop species and year
if (length(remaining) >= 2 &&
remaining[length(remaining) - 1] == "Migration" &&
grepl("^Route", remaining[length(remaining)])) {
route_type <- "Migration_Route"
herd_parts <- remaining[-c(length(remaining) - 1, length(remaining))]
} else if (grepl("^Stopover", remaining[length(remaining)])) {
route_type <- "Stopover"
herd_parts <- remaining[-length(remaining)]
} else {
route_type <- NA
herd_parts <- remaining
}
herd <- paste(herd_parts, collapse = "_")
data.frame(
layer    = nm,
species  = as.character(species),
herd     = herd,
type     = route_type,
year     = year,
stringsAsFactors = FALSE
)
}
# ── Build metadata table, skip non-wildlife layers ───────────────────────────
skip_layers <- c("Priority_Area", "Eastern_Idaho_Regions")
meta <- do.call(rbind, lapply(layer_names[!layer_names %in% skip_layers], parse_layer_name))
meta <- meta[!is.na(meta$type), ]
cat("Layers to process:", nrow(meta), "\n")
print(meta)
# ── Read and tag each layer ───────────────────────────────────────────────────
read_layer <- function(row) {
lyr <- st_read(gdb, layer = row$layer, quiet = TRUE)
lyr$species      <- row$species
lyr$herd         <- row$herd
lyr$type         <- row$type
lyr$year         <- row$year
lyr$source_layer <- row$layer
# Keep only our standardized columns + geometry so rbind doesn't fail
lyr <- lyr[, c("species", "herd", "type", "year", "source_layer")]
lyr
}
# ── Read all layers ───────────────────────────────────────────────────────────
cat("Reading", nrow(meta), "layers...\n")
all_list <- lapply(seq_len(nrow(meta)), function(i) {
cat("  ", meta$layer[i], "\n")
read_layer(meta[i, ])
})
all_combined <- bind_rows(all_list)
cat("\nTotal features read:", nrow(all_combined), "\n")
# ── Write one file per species + type ────────────────────────────────────────
out_dir <- "D:/GIS/projects/GreaterYellowstoneCoalition/GYC_Map_Viewer/data/IFWIS_DataRequest__GYC_MigrationsStopovers_042026"
groups <- unique(all_combined[, c("species", "type"), drop = TRUE])
# drop sf geometry column for the unique() call
groups <- unique(data.frame(species = all_combined$species, type = all_combined$type,
stringsAsFactors = FALSE))
cat("\nWriting", nrow(groups), "output files...\n")
for (i in seq_len(nrow(groups))) {
sp   <- groups$species[i]
tp   <- groups$type[i]
subset_sf <- all_combined[all_combined$species == sp & all_combined$type == tp, ]
# Build a safe filename: e.g. "Mule_Deer_Migration_Route.gpkg"
sp_safe <- gsub(" ", "_", sp)
fname   <- paste0(sp_safe, "_", tp, ".gpkg")
fpath   <- file.path(out_dir, fname)
st_write(subset_sf, fpath, delete_dsn = TRUE, quiet = TRUE)
cat("  Wrote", nrow(subset_sf), "features ->", fname,
" | years:", paste(sort(unique(subset_sf$year)), collapse = ", "), "\n")
}
