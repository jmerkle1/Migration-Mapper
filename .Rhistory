lyr <- st_read(gdb, layer = row$layer, quiet = TRUE)
lyr$species  <- row$species
lyr$herd     <- row$herd
lyr$type     <- row$type
lyr$year     <- row$year
lyr$source_layer <- row$layer
# Normalize geometry to MULTILINESTRING or MULTIPOLYGON for safe binding
lyr <- st_cast(lyr, warn = FALSE)
lyr
}
# ── Read all layers ───────────────────────────────────────────────────────────
cat("Reading", nrow(meta), "layers...\n")
